# BeLLMark Environment Configuration

# Encryption key for storing API keys (REQUIRED)
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
BELLMARK_SECRET_KEY=

# API key authentication
#
# Two modes — pick exactly one:
#
#   1. Local development (default):
#        Leave BELLMARK_API_KEY commented out and set BELLMARK_DEV_MODE=true
#        below. All API endpoints accept requests without authentication.
#        Fine for localhost-only use. NOT SAFE if the port is exposed.
#
#   2. Production / LAN / public:
#        Set BELLMARK_API_KEY to a strong random value. All /api/* routes
#        will then require the `X-API-Key` header (WebSockets use a first-
#        message auth frame). The UI prompts for the key on first load.
#        Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# If BOTH are unset, BeLLMark fails closed (returns HTTP 503 on /api/*)
# to prevent accidentally-exposed unauthenticated instances.
#
# BELLMARK_API_KEY=
BELLMARK_DEV_MODE=true

# Cloud provider API keys (optional — can also be set per model preset in the UI)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
GROK_API_KEY=
GLM_API_KEY=
KIMI_API_KEY=
OPENROUTER_API_KEY=

# Server Configuration
# Note: BACKEND_HOST=127.0.0.1 is correct for ./start.sh (dev mode).
# Docker Compose overrides this to 0.0.0.0 automatically.
BACKEND_HOST=127.0.0.1
# Port 8000 is common — change if you have a conflict
BACKEND_PORT=8000
FRONTEND_PORT=5173

# CORS allowed origins (comma-separated, defaults to localhost)
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000
